{
  "name": "oz-erp-edge",
  "version": "0.1.0",
  "description": "Cloudflare Hono Worker gateway for the private oz-erp-api Cloud Run service.",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24.0.0 <25.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "wrangler dev --local --port 8787",
    "dev:remote": "wrangler dev --local=false",
    "build": "wrangler deploy --dry-run --outdir dist --strict",
    "deploy": "wrangler deploy --strict",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "lint": "eslint . --max-warnings=0",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "audit:prod": "npm audit --omit=dev --audit-level=high",
    "verify": "npm run cf:typegen:check && npm run typecheck && npm run lint && npm run format:check && npm run build && npm run audit:prod",
    "cf:typegen": "wrangler types src/worker-configuration.d.ts",
    "cf:typegen:check": "wrangler types src/worker-configuration.d.ts --check",
    "cf:startup": "wrangler check startup"
  },
  "dependencies": {
    "hono": "4.12.30",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.5",
    "eslint": "9.39.5",
    "eslint-config-prettier": "10.1.8",
    "globals": "16.5.0",
    "prettier": "3.9.5",
    "typescript": "5.9.3",
    "typescript-eslint": "8.64.0",
    "wrangler": "4.110.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "sharp@0.34.5": true,
    "workerd@1.20260708.1": true
  },
  "packageManager": "npm@11.16.0"
}
